# ============================================================
# StreamSpeech — Root .gitignore
# Keep repository source-only; exclude runtime, models, and caches.
# ============================================================

# Python
venv/
.venv/
env/
backend/venv/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/
*.egg
.Python
pip-log.txt
pip-delete-this-directory.txt

# Models & weights (downloaded at runtime)
pretrained_models/
models/
checkpoints/
weights/
backend/pretrained_models/
*.pt
*.pth
*.bin
*.onnx
*.ckpt
*.safetensors

# Node / frontend build
node_modules/
streamspeech/node_modules/
dist/
build/
streamspeech/dist/
streamspeech/.vite/
.next/
*.tsbuildinfo

# Generated audio (runtime)
temp_audio/
backend/temp_audio/
static/audio/
backend/static/audio/
*.webm
*.wav
*.mp3

# Environment & secrets
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# Databases (runtime analytics)
*.db
*.sqlite
*.sqlite3
backend/data/

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# v0 / Vercel scaffold (unused)
.snowflake/
.v0-trash/
.vercel/
__v0_*

# Package manager locks in wrong places (keep package-lock.json)
pnpm-lock.yaml

# Docker runtime volumes (keep Dockerfiles)
# (none)

# Metrics output (regenerated by evaluate_metrics.py)
backend/metrics_output/

# Temporary / scratch
*.tmp
*.temp
.cache/
